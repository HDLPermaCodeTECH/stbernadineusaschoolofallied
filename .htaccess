# ----------------------------------------------------------------------
# | Security                                                           |
# ----------------------------------------------------------------------

# 1. Prevent Directory Listing
Options -Indexes -MultiViews

# 2. Block access to sensitive files
<FilesMatch "^\.env|^\.git|^\.htaccess|^package|^node_modules|^\.gitignore">
    Order allow,deny
    Deny from all
</FilesMatch>

# 3. Security Headers
<IfModule mod_headers.c>
    # Prevents IE and Chrome from MIME-sniffing a response away from the declared content-type
    Header set X-Content-Type-Options "nosniff"

    # Protect against XSS attacks
    Header set X-XSS-Protection "1; mode=block"

    # Prevent site from being embedded in frames (Clickjacking)
    Header set X-Frame-Options "SAMEORIGIN"

    # Enforce HTTPS (HSTS) - set for 1 year
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Referrer Policy
    Header set Referrer-Policy "no-referrer-when-downgrade"

    # Remove X-Powered-By header (Hide server info)
    Header unset X-Powered-By
</IfModule>

# ----------------------------------------------------------------------
# | Rewrites & Enforcements                                            |
# ----------------------------------------------------------------------

RewriteEngine On
RewriteBase /

# 301 Redirect for renamed services page
Redirect 301 /services.html /school-of-allied-health-services/
Redirect 301 /services /school-of-allied-health-services/
Redirect 301 /school-of-allied-health-services.html /school-of-allied-health-services/

# 1. Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Redirect /index.html to the root directory (/)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.html\ HTTP/ [NC]
RewriteRule ^index\.html$ / [R=301,L]

# 3. Externally redirect direct .html requests to the extensionless version (301)
RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# 4. Internally rewrite extensionless requests to append .html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ /$1.html [L]

# ----------------------------------------------------------------------
# | Performance                                                        |
# ----------------------------------------------------------------------

# 1. Enable Gzip Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>

# 2. Browser Caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
